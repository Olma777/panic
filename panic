  esac
}

usage() { t usage; }

# Точки монтирования смонтированных disk image'ов под /Volumes (vault'ы, dmg).
# Парсим `hdiutil info`: dev-строки TAB-разделены → mountpoint (3-е поле) корректен
# даже с пробелами. Фильтр /Volumes/ исключает system-образы (монтируются вне /Volumes).
_mounted_images() {
  hdiutil info 2>/dev/null | awk -F'\t' '/^\/dev\/disk/ && $3 ~ /^\/Volumes\// {print $3}'
}

# Блокировка экрана через настраиваемый локер.
# Заблокировать экран. Возвращает 0 ТОЛЬКО если блокировка реально инициирована — иначе
# cmd_now честно сообщит, что экран НЕ заперт (а не соврёт «locked screen», как раньше при
# молча падавшем CGSession на современных macOS). Методы по убыванию надёжности.
_lock_screen() {
  if [[ -x "$PANIC_CGSESSION" ]] && "$PANIC_CGSESSION" -suspend >/dev/null 2>&1; then
    return 0
  fi
  # Ctrl+Cmd+Q — системный лок на современном macOS. Без Accessibility-доступа osascript
  # вернёт ошибку → честно НЕ считаем за успех.
  if [[ -x "$PANIC_OSASCRIPT" ]] && \
     "$PANIC_OSASCRIPT" -e 'tell application "System Events" to keystroke "q" using {control down, command down}' >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

# --hard: прибить известные cloud-демоны (best-effort, отсутствие процесса — не ошибка).
_kill_cloud_daemons() {
  local d
  for d in "${PANIC_CLOUD_DAEMONS[@]}"; do
    pkill -x "$d" >/dev/null 2>&1 || true
  done
}

# --hard: почистить Recent items (shared file lists). ЧЕСТНО: покрывает глобальные
# списки в PANIC_SFL_DIR; per-app «недавние» внутри приложений этим не стираются.
_clear_recent_items() {
  rm -f "$PANIC_SFL_DIR"/*.sfl* 2>/dev/null || true
}

# Kill-switch: спрятать и запереть. БЕЗ confirm — это режим паники (скорость важнее);
# защита от случайного запуска — явный verb `now`. detach -force при открытых файлах
# может повредить данные: осознанный trade-off (см. README «Scope & limitations»).
cmd_now() {
  require_macos
  local hard=0 a
  for a in "$@"; do
    case "$a" in --hard) hard=1 ;; esac
  done

  # 1. Размонтировать все смонтированные disk image'ы (force — паника важнее открытых файлов).
  local n=0 mp
  while IFS= read -r mp; do
    [[ -n "$mp" ]] || continue
    if hdiutil detach -force "$mp" >/dev/null 2>&1; then
      n=$((n + 1))
    else
      warn "$(t detach_fail "$mp")"
    fi
  done < <(_mounted_images)

  # 2. Очистить буфер обмена. 3. Заблокировать экран (статус — для честного отчёта).
  pbcopy </dev/null >/dev/null 2>&1 || true
  local locked=0
  if _lock_screen; then locked=1; fi

  # 4. --hard: прибить cloud-демоны + почистить Recent items.
  if [[ "$hard" == "1" ]]; then
    _kill_cloud_daemons
    _clear_recent_items
  fi

  info "$(t now_report "$n")"
  if [[ "$locked" == "1" ]]; then info "$(t lock_ok)"; else warn "$(t lock_fail)"; fi
  if [[ "$hard" == "1" ]]; then info "$(t now_hard)"; fi
}

cmd_status() {
  require_macos
  info "$(t status_header)"

  # Смонтированные disk image'ы (vault'ы, dmg) — `panic now` размонтирует их.
  local images=() mp
  while IFS= read -r mp; do
    [[ -n "$mp" ]] && images+=("$mp")
  done < <(_mounted_images)
  if [[ ${#images[@]} -gt 0 ]]; then
    info "$(t status_images "${#images[@]}")"
    for mp in "${images[@]}"; do printf '    %s\n' "$mp"; done
  else
    info "$(t status_no_images)"
  fi

  # Буфер обмена.
  local clip_size; clip_size="$(pbpaste 2>/dev/null | wc -c | tr -d ' ')"
  if [[ "${clip_size:-0}" -gt 0 ]]; then
    info "$(t status_clip_has)"
  else
    info "$(t status_clip_empty)"
  fi

  # FileVault — честный контекст.
  if filevault_on; then
    info "$(t status_fv_on)"
  else
    warn "$(t status_fv_off)"
  fi

  # Cloud-демоны (--hard убьёт).
  local d
  for d in "${PANIC_CLOUD_DAEMONS[@]}"; do
    if pgrep -x "$d" >/dev/null 2>&1; then
      info "$(t status_cloud "$d")"
    fi
  done
}

# Убрать managed-блок panic из skhd-конфига (чужие строки не трогаем). awk сравнивает
# строки литерально — без возни с экранированием спецсимволов в маркерах.
_hotkey_strip() {
  [[ -f "$SKHD_CONFIG" ]] || return 0
  local tmp; tmp="$(mktemp)"
  # Удаляем ТОЛЬКО полные managed-блоки (begin..end). Незакрытый блок (повреждённый
  # конфиг) НЕ режем до конца файла — буферизуем и возвращаем, чтобы не снести чужие строки.
  awk -v b="$PANIC_HK_BEGIN" -v e="$PANIC_HK_END" '
    $0==b && !inblock { inblock=1; buf=$0 ORS; next }
    inblock { buf=buf $0 ORS; if ($0==e) { inblock=0; buf="" } next }
    { print }
    END { if (inblock) printf "%s", buf }
  ' "$SKHD_CONFIG" > "$tmp" && mv "$tmp" "$SKHD_CONFIG"
}

# (Пере)запустить skhd-сервис best-effort: для уже установленного сервиса хватает restart;
# на чистой системе — install + start. Ошибки не валят команду (skhd может требовать прав).
_hotkey_reload() {
  command -v skhd >/dev/null 2>&1 || return 0
  skhd --restart-service >/dev/null 2>&1 && return 0
  skhd --install-service >/dev/null 2>&1 || true
  skhd --start-service   >/dev/null 2>&1 || true
}

# Глобальный хоткей паники через skhd. Лаунчер хоткея только дёргает `panic now` —
# секретов не трогает. Конфиг-блок managed, не затирает чужие биндинги skhd.
cmd_hotkey() {
  require_macos
  local sub="${1:-status}"; shift || true
  case "$sub" in
    install)
      command -v skhd >/dev/null 2>&1 || { err "$(t hk_no_skhd)"; exit 1; }
      local combo="${1:-$PANIC_HOTKEY_COMBO}"
      # combo не должен содержать ':' (разделитель skhd) или перевод строки — иначе можно
      # инжектить лишние строки/биндинги в skhdrc.
      if [[ "$combo" == *:* || "$combo" == *$'\n'* ]]; then err "$(t hk_bad_combo)"; exit 1; fi
      local self; self="$(_abspath "${BASH_SOURCE[0]}")"
      mkdir -p "$(dirname "$SKHD_CONFIG")"
      _hotkey_strip
      # Разделитель считаем ДО открытия редиректа (иначе shellcheck SC2094: read+write).
      local sep=""
      [[ -s "$SKHD_CONFIG" ]] && sep=$'\n'
      {
        printf '%s' "$sep"
        printf '%s\n' "$PANIC_HK_BEGIN"
        # Путь закавычен: установка идёт из путей с пробелами (напр. /Volumes/X10 Pro/...);
        # без кавычек skhd разорвал бы команду по пробелу.
        printf '%s : "%s" now\n' "$combo" "$self"
        printf '%s\n' "$PANIC_HK_END"
      } >> "$SKHD_CONFIG"
      _hotkey_reload
      info "$(t hk_installed "$combo")"
      warn "$(t hk_accessibility)"
      ;;
    uninstall)
      _hotkey_strip
      _hotkey_reload
      info "$(t hk_uninstalled)"
      ;;
    status)
      if [[ -f "$SKHD_CONFIG" ]] && grep -qF "$PANIC_HK_BEGIN" "$SKHD_CONFIG"; then
        local line; line="$(grep -A1 -F "$PANIC_HK_BEGIN" "$SKHD_CONFIG" | tail -1)"
        info "$(t hk_status_on "$line")"
      else
        info "$(t hk_status_off)"
      fi
      command -v skhd >/dev/null 2>&1 || warn "$(t hk_no_skhd)"
      ;;
    *) err "$(t hk_usage)"; exit 1 ;;
  esac
}

cmd_version() { echo "panic $VERSION"; }

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then usage; exit 1; fi
  shift || true
  case "$cmd" in
    status)          cmd_status "$@" ;;
    version|-v|--version) cmd_version "$@" ;;
    help|--help|-h) usage ;;
    now)           cmd_now "$@" ;;
    hotkey)        cmd_hotkey "$@" ;;
    *) t unknown_cmd "$cmd" >&2; echo >&2; usage >&2; exit 1 ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
