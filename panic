  local key="$1"; shift
  # Все строки ниже — литеральный display-текст; бэктики в них не подстановка команды.
  # shellcheck disable=SC2016
  case "$ST_LOCALE:$key" in
    en:usage)
      cat <<'EOF'
Usage: panic <command> [args]

Commands:
  status              Read-only preflight: show what `panic now` would affect.
  now [--hard]        Hide & lock now: close vaults, detach volumes, clear
                      clipboard, lock screen. --hard also kills cloud daemons.
  hotkey <sub>        Global panic hotkey via skhd: install [combo] | uninstall | status.
                      Default combo: cmd + alt - p. Needs skhd + Accessibility.
  version             Show the version

panic HIDES and LOCKS — it does NOT destroy or wipe swap (use securetrash to
destroy). detach -force may corrupt open files — a deliberate panic trade-off.
EOF
      ;;
    ru:usage)
      cat <<'EOF'
Usage: panic <command> [args]

Commands:
  status              Только чтение: что затронет `panic now` (безопасно, предпросмотр).
  now [--hard]        Спрятать и запереть сейчас: закрыть vault'ы, размонтировать
                      тома, очистить буфер, заблокировать экран. --hard также
                      прибивает cloud-демоны.
  hotkey <sub>        Глобальный хоткей паники через skhd: install [combo] | uninstall | status.
                      Комбинация по умолчанию: cmd + alt - p. Нужны skhd + Accessibility.
  version             Показать версию

panic ПРЯЧЕТ и ЗАПИРАЕТ — НЕ уничтожает и НЕ чистит swap (для уничтожения —
securetrash). detach -force может повредить открытые файлы — осознанный trade-off.
EOF
      ;;
    en:unknown_cmd) printf 'Unknown command: %s' "$1" ;;
    ru:unknown_cmd) printf 'Unknown command: %s' "$1" ;;
    en:status_header)    echo 'panic status — read-only preflight (no changes made)' ;;
    ru:status_header)    echo 'panic status — только чтение, предпросмотр (изменений нет)' ;;
    en:status_images)    printf '  disk images mounted: %s — would be detached by `panic now`' "$1" ;;
    ru:status_images)    printf '  смонтированных образов: %s — будут размонтированы `panic now`' "$1" ;;
    en:status_no_images) echo  '  disk images: none mounted' ;;
    ru:status_no_images) echo  '  образов: не смонтировано' ;;
    en:status_clip_has)  echo  '  clipboard: non-empty — would be cleared' ;;
    ru:status_clip_has)  echo  '  буфер обмена: не пуст — будет очищен' ;;
    en:status_clip_empty) echo '  clipboard: empty' ;;
    ru:status_clip_empty) echo '  буфер обмена: пуст' ;;
    en:status_fv_on)     echo  '  FileVault: ON — crypto-shred effective on vault close' ;;
    ru:status_fv_on)     echo  '  FileVault: ВКЛ — crypto-shred эффективен при закрытии vault' ;;
    en:status_fv_off)    echo  '  FileVault: OFF — disk not encrypted (vault at risk if drive seized)' ;;
    ru:status_fv_off)    echo  '  FileVault: ВЫКЛ — диск не зашифрован (vault под угрозой при изъятии)' ;;
    en:status_cloud)     printf '  cloud daemon running: %s — would be killed by `panic now --hard`' "$1" ;;
    ru:status_cloud)     printf '  cloud-демон запущен: %s — будет убит `panic now --hard`' "$1" ;;
    en:detach_fail) printf 'could not detach %s (may have open files).' "$1" ;;
    ru:detach_fail) printf 'не удалось размонтировать %s (возможно, открыты файлы).' "$1" ;;
    en:now_hard) echo 'panic --hard: cloud daemons killed, recent items cleared.' ;;
    ru:now_hard) echo 'panic --hard: cloud-демоны убиты, recent items очищены.' ;;
    en:now_report) printf 'panic: detached %s disk image(s), cleared clipboard.' "$1" ;;
    ru:now_report) printf 'panic: размонтировано образов: %s, буфер очищен.' "$1" ;;
    en:lock_ok)    echo 'screen locked.' ;;
