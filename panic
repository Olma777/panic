#!/usr/bin/env bash
# panic — kill-switch на один шаг (экосистема Paranoid Tools).
#
# Сценарий: граница / принуждение / «кто-то идёт». Одной командой `panic now`
# прячет и запирает: закрывает открытые vault'ы securetrash, размонтирует тома,
# чистит буфер обмена и блокирует экран. Удобно повесить на хоткей через launchd.
#
# ЧЕСТНО: panic ПРЯЧЕТ и ЗАПИРАЕТ, но НЕ уничтожает и НЕ чистит swap (для
# уничтожения — securetrash). `detach -force` при открытых файлах может повредить
# данные — осознанный trade-off режима паники (спрятать важнее). Полное ядро —
# в следующих паках; см. README «Scope & limitations».
set -euo pipefail

VERSION="0.1.0"

# Локер экрана. По умолчанию CGSession -suspend (реальная блокировка до login-window,
# не зависит от настройки «требовать пароль» — в отличие от pmset/screensaver).
# Переопределяемо (тесты/иные механизмы блокировки).
PANIC_CGSESSION="${PANIC_CGSESSION:-/System/Library/CoreServices/Menu Extras/User.menu/Contents/Resources/CGSession}"

# Каталог shared file lists (Recent items). Переопределяемо для тестов.
PANIC_SFL_DIR="${PANIC_SFL_DIR:-${HOME}/Library/Application Support/com.apple.sharedfilelist}"

# Cloud-демоны, которых --hard прибивает (точные имена процессов для pkill -x).
PANIC_CLOUD_DAEMONS=(Dropbox OneDrive bird "Google Drive")

# === BEGIN vendored common (pin: 2e3d2dd5b36251bdcb1a8ffd348b63ece5fa7aab) ===
# shellcheck shell=bash
# common.sh — переиспользуемые примитивы экосистемы Paranoid Tools.
#
# Канонический источник: securetrash/lib/common.sh. Инструменты экосистемы
# (vaultwatch/panic/ghostdraft) вендорят его inline между маркерами
# (см. CLAUDE.md «Vendoring»). Файл sourceable и идемпотентен (двойной source/inline
# безопасны — guard через if-обёртку, без top-level return, поэтому корректен и когда
# блок вставлен в исполняемый скрипт).
#
# Даёт tool-агностичные примитивы: локаль (ST_LOCALE), цветной вывод (info/warn/err),
# подтверждение (confirm), детект платформы macOS (require_macos/is_ssd/_disk_kind/
# filevault_on), канонизацию пути (_abspath). Своя i18n-таблица — у каждого инструмента.
#
# ВЕНДОРИНГ — зарезервированные имена (не переопределять в host-скрипте): функции
# info warn err confirm require_macos is_ssd _disk_kind filevault_on _abspath
# _st_detect_locale; переменные ST_LOCALE C_RED C_GRN C_YEL C_RST _ST_COMMON_LOADED.

# Идемпотентность через if-обёртку (а не top-level return): безопасно при source,
# исполнении и inline-вставке. Определения функций внутри if регистрируются глобально.
if [[ -z "${_ST_COMMON_LOADED:-}" ]]; then
  _ST_COMMON_LOADED=1

  # --- locale ---
  # en по умолчанию; ru — если ST_LANG или системная локаль начинаются с 'ru'.
  _st_detect_locale() {
    local want="${ST_LANG:-}"
    if [[ -n "$want" ]]; then
      case "$want" in ru*) echo ru ;; *) echo en ;; esac
      return
    fi
    local sys="${LC_ALL:-${LANG:-}}"
    case "$sys" in ru*) echo ru ;; *) echo en ;; esac
  }
  # Уважаем заранее выставленный ST_LOCALE (host может переопределить).
  ST_LOCALE="${ST_LOCALE:-$(_st_detect_locale)}"

  # --- output ---
  # Цвет только в TTY (в пайпах/файлах — без ANSI).
  if [[ -t 1 ]]; then
    C_RED=$'\033[31m'; C_GRN=$'\033[32m'; C_YEL=$'\033[33m'; C_RST=$'\033[0m'
  else
    C_RED=""; C_GRN=""; C_YEL=""; C_RST=""
  fi
  info() { echo "${C_GRN}✓${C_RST} $*"; }
  warn() { echo "${C_YEL}!${C_RST} $*" >&2; }
  err()  { echo "${C_RED}✗${C_RST} $*" >&2; }

  # --- confirm ---
  # Подтверждение необратимой операции. ST_ASSUME_YES=1 обходит вопрос (скрипты/тесты).
  # Возвращает 0 только при точном вводе 'yes' (EOF/пусто → отказ, fail-closed).
  # Суффикс намеренно продублирован из i18n securetrash (lib без таблицы строк).
  confirm() {
    local prompt="$1" ans suffix
    [[ "${ST_ASSUME_YES:-0}" == "1" ]] && return 0
    case "$ST_LOCALE" in ru) suffix="[введите yes]" ;; *) suffix="[type yes]" ;; esac
    read -r -p "$prompt $suffix: " ans
    [[ "$ans" == "yes" ]]
  }

  # --- platform (macOS) ---
  require_macos() {
    if [[ "$(uname -s)" != "Darwin" ]]; then
      case "$ST_LOCALE" in
        ru) err "работает только на macOS." ;;
        *)  err "runs on macOS only." ;;
      esac
      exit 1
    fi
  }

  # Диск под путём — SSD? (diskutil info: "Solid State: Yes")
  is_ssd() {
    local path="${1:-/}"
    diskutil info "$path" 2>/dev/null | grep -qi "Solid State:.*Yes"
  }

  # Тип диска: ssd | hdd | unknown. Честность важнее догадок: неизвестный тип
  # НЕ приравниваем к hdd-эффективному (нет поля "Solid State" → unknown).
  _disk_kind() {
    local path="${1:-/}" out
    out="$(diskutil info "$path" 2>/dev/null)"
    if grep -qi "Solid State:.*Yes" <<<"$out"; then echo ssd
    elif grep -qi "Solid State:.*No" <<<"$out"; then echo hdd
    else echo unknown; fi
  }

  # FileVault включён? (fdesetup status: "FileVault is On.")
  filevault_on() {
    fdesetup status 2>/dev/null | grep -qi "FileVault is On"
  }

  # --- path ---
  # Физический канонический путь: режет trailing-slash, резолвит .. и симлинки,
  # ВКЛЮЧАЯ финальный компонент. Непустая строка или код !=0, если путь недоступен.
  _abspath() {
    local p="$1"
    while [[ "$p" == */ && "$p" != "/" ]]; do p="${p%/}"; done
    if [[ -d "$p" ]]; then
      ( cd -P -- "$p" 2>/dev/null && pwd -P ); return
    fi
    local d b
    d="$(cd -P -- "$(dirname -- "$p")" 2>/dev/null && pwd -P)" || return 1
    b="$(basename -- "$p")"
    printf '%s/%s' "${d%/}" "$b"
  }
fi
# === END vendored common ===

# --- i18n (таблица строк panic; общие примитивы — в vendored common) ---
t() {
  local key="$1"; shift
  case "$ST_LOCALE:$key" in
    en:usage)
      cat <<'EOF'
Usage: panic <command> [args]

Commands:
  now [--hard]        Hide & lock now: close vaults, detach volumes, clear
                      clipboard, lock screen. --hard also kills cloud daemons.
  version             Show the version

panic HIDES and LOCKS — it does NOT destroy or wipe swap (use securetrash to
destroy). detach -force may corrupt open files — a deliberate panic trade-off.
EOF
      ;;
    ru:usage)
      cat <<'EOF'
Usage: panic <command> [args]

Commands:
  now [--hard]        Спрятать и запереть сейчас: закрыть vault'ы, размонтировать
                      тома, очистить буфер, заблокировать экран. --hard также
                      прибивает cloud-демоны.
  version             Показать версию

panic ПРЯЧЕТ и ЗАПИРАЕТ — НЕ уничтожает и НЕ чистит swap (для уничтожения —
securetrash). detach -force может повредить открытые файлы — осознанный trade-off.
EOF
      ;;
    en:unknown_cmd) printf 'Unknown command: %s' "$1" ;;
    ru:unknown_cmd) printf 'Unknown command: %s' "$1" ;;
    en:detach_fail) printf 'could not detach %s (may have open files).' "$1" ;;
    ru:detach_fail) printf 'не удалось размонтировать %s (возможно, открыты файлы).' "$1" ;;
    en:now_hard) echo 'panic --hard: cloud daemons killed, recent items cleared.' ;;
    ru:now_hard) echo 'panic --hard: cloud-демоны убиты, recent items очищены.' ;;
    en:now_report) printf 'panic: detached %s disk image(s), cleared clipboard, locked screen.' "$1" ;;
    ru:now_report) printf 'panic: размонтировано образов: %s, буфер очищен, экран заперт.' "$1" ;;
    *) echo "$key" ;;
  esac
}

usage() { t usage; }

# Точки монтирования смонтированных disk image'ов под /Volumes (vault'ы, dmg).
# Парсим `hdiutil info`: dev-строки TAB-разделены → mountpoint (3-е поле) корректен
# даже с пробелами. Фильтр /Volumes/ исключает system-образы (монтируются вне /Volumes).
_mounted_images() {
  hdiutil info 2>/dev/null | awk -F'\t' '/^\/dev\/disk/ && $3 ~ /^\/Volumes\// {print $3}'
}

# Блокировка экрана через настраиваемый локер.
_lock_screen() {
  "$PANIC_CGSESSION" -suspend >/dev/null 2>&1 || true
}

# --hard: прибить известные cloud-демоны (best-effort, отсутствие процесса — не ошибка).
_kill_cloud_daemons() {
  local d
  for d in "${PANIC_CLOUD_DAEMONS[@]}"; do
    pkill -x "$d" >/dev/null 2>&1 || true
  done
}

# --hard: почистить Recent items (shared file lists). ЧЕСТНО: покрывает глобальные
# списки в PANIC_SFL_DIR; per-app «недавние» внутри приложений этим не стираются.
_clear_recent_items() {
  rm -f "$PANIC_SFL_DIR"/*.sfl* 2>/dev/null || true
}

# Kill-switch: спрятать и запереть. БЕЗ confirm — это режим паники (скорость важнее);
# защита от случайного запуска — явный verb `now`. detach -force при открытых файлах
# может повредить данные: осознанный trade-off (см. README «Scope & limitations»).
cmd_now() {
  require_macos
  local hard=0 a
  for a in "$@"; do
    case "$a" in --hard) hard=1 ;; esac
  done

  # 1. Размонтировать все смонтированные disk image'ы (force — паника важнее открытых файлов).
  local n=0 mp
  while IFS= read -r mp; do
    [[ -n "$mp" ]] || continue
    if hdiutil detach -force "$mp" >/dev/null 2>&1; then
      n=$((n + 1))
    else
      warn "$(t detach_fail "$mp")"
    fi
  done < <(_mounted_images)

  # 2. Очистить буфер обмена. 3. Заблокировать экран.
  pbcopy </dev/null >/dev/null 2>&1 || true
  _lock_screen

  # 4. --hard: прибить cloud-демоны + почистить Recent items.
  if [[ "$hard" == "1" ]]; then
    _kill_cloud_daemons
    _clear_recent_items
  fi

  info "$(t now_report "$n")"
  if [[ "$hard" == "1" ]]; then info "$(t now_hard)"; fi
}

cmd_version() { echo "panic $VERSION"; }

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then usage; exit 1; fi
  shift || true
  case "$cmd" in
    version)       cmd_version "$@" ;;
    help|--help|-h) usage ;;
    now)           cmd_now "$@" ;;
    *) t unknown_cmd "$cmd" >&2; echo >&2; usage >&2; exit 1 ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
